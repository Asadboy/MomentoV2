// Secrets.example.xcconfig
// Template — copy this to Secrets.xcconfig and fill in real values.
// Secrets.xcconfig is gitignored; this example file is committed.
//
// NOTE on URLs: xcconfig treats `//` as a comment, so any value containing
// `https://` must escape it as `https:/$()/`. The `$()` is an empty xcconfig
// variable substitution that resolves to nothing at build time, leaving a
// valid `https://` URL. This applies to SUPABASE_URL, POSTHOG_HOST, and
// SENTRY_DSN.

SUPABASE_URL = https:/$()/YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_KEY
POSTHOG_API_KEY = YOUR_POSTHOG_API_KEY
POSTHOG_HOST = https:/$()/eu.i.posthog.com

// SENTRY_DSN — Sentry dashboard → Settings → Projects → <project> →
// Client Keys (DSN). Leave as YOUR_SENTRY_DSN until a project exists;
// CrashReporter.start() skips Sentry init gracefully if it's unset or
// still the placeholder.
SENTRY_DSN = YOUR_SENTRY_DSN
